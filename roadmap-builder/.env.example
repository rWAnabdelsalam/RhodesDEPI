# ==========================================
# RoadMap Builder - Environment Variables
# Copy this file to .env in the /api folder
# and fill in your real values.
# NEVER commit your real .env file.
# ==========================================

# MongoDB Atlas connection string (cloud only, no local MongoDB)
# Get this from MongoDB Atlas -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/roadmap-builder?retryWrites=true&w=majority

# Gemini API key (free tier available at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: comma-separated list of additional Gemini API keys for automatic
# failover if one key hits its quota or an error. The code tries them in
# order and stops at the first one that works. You can add as many as you want.
GEMINI_API_KEYS=key_one,key_two,key_three

# Optional: primary model + comma-separated fallback models, tried in order
# per key. Keep this list short — each extra model/key combo adds worst-case
# latency, and the Vercel function has a maxDuration ceiling (see vercel.json).
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# Port for the local Express server (Vercel ignores this in production)
PORT=5000

# JWT secret used to sign simple auth tokens (any long random string)
JWT_SECRET=replace_with_a_long_random_string

# Comma-separated list of allowed origins for CORS (add your Vercel URL after deploying)
CLIENT_ORIGIN=http://localhost:5173
